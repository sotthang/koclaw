# LLM Providers (최소 하나 필요)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama (로컬 LLM, 설치 시 기본값 사용 가능)
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Slack (koclaw[slack] 설치 시 필요)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Discord (koclaw[discord] 설치 시 필요)
DISCORD_BOT_TOKEN=your-discord-bot-token

# Gmail SMTP (koclaw[email] 설치 시 필요, 이메일 전송 도구)
# Google 계정 → 보안 → 앱 비밀번호에서 16자리 비밀번호 발급 (2단계 인증 필요)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Windows 네이티브 데스크탑 제어 (windows_agent/server.py 실행 후 URL 설정)
# 설정 시 Docker 대신 Windows Agent를 통해 실제 Windows 화면을 제어합니다
# WSL에서 Windows Agent 접근: http://$(cat /etc/resolv.conf | grep nameserver | awk '{print $2}'):7777
# Tailscale 사용 시: http://<tailscale-ip>:7777
# WINDOWS_AGENT_URL=http://localhost:7777
# WINDOWS_AGENT_API_KEY=your-secret-key-here  # install.ps1 실행 시 자동 생성됨

# LLM 설정
DEFAULT_LLM_PROVIDER=gemini   # claude | openai | gemini | ollama
# FALLBACK_LLM_PROVIDERS=claude,openai   # 실패 시 순서대로 폴백 (쉼표 구분)

# provider별 모델 설정 (미설정 시 각 provider 기본값 사용)
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.3
GEMINI_MODEL=gemini-3-flash-preview
OLLAMA_MODEL=llama3.3
