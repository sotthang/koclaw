# LLM Providers (최소 하나 필요)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama (로컬 LLM, 설치 시 기본값 사용 가능)
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Slack (koclaw[slack] 설치 시 필요)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Discord (koclaw[discord] 설치 시 필요)
DISCORD_BOT_TOKEN=your-discord-bot-token

# 웹훅 서버 (외부 서비스 이벤트 수신 — GitHub, CI/CD, 모니터링 등)
# WEBHOOK_HOST: 외부에서 접근 가능한 주소 (Tailscale Funnel, 개인 도메인, ngrok 등)
# WEBHOOK_PORT: 서버 포트 (기본값 8080)
# WEBHOOK_HOST=https://your-host.ts.net
# WEBHOOK_PORT=8080

# CalDAV 캘린더 연동 (koclaw[calendar] 설치 시 필요, iCloud 캘린더 조회/추가/수정/삭제)
# iCloud 앱 전용 비밀번호: appleid.apple.com → 로그인 및 보안 → 앱 암호
# CALDAV_URL=https://caldav.icloud.com
# CALDAV_USERNAME=your@icloud.com
# CALDAV_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Gmail SMTP (koclaw[email] 설치 시 필요, 이메일 전송 도구)
# Google 계정 → 보안 → 앱 비밀번호에서 16자리 비밀번호 발급 (2단계 인증 필요)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Windows 네이티브 데스크탑 제어 (windows_agent/server.py 실행 후 URL 설정)
# 설정 시 Docker 대신 Windows Agent를 통해 실제 Windows 화면을 제어합니다
# WSL에서 Windows Agent 접근: http://$(cat /etc/resolv.conf | grep nameserver | awk '{print $2}'):7777
# Tailscale 사용 시: http://<tailscale-ip>:7777
# WINDOWS_AGENT_URL=http://localhost:7777        # WSL에서 Windows Agent 접근 (내부 IP)
# WINDOWS_AGENT_VIEW_URL=http://100.x.x.x:7777  # 브라우저/채팅에 표시할 공개 URL (Tailscale 등, 미설정 시 WINDOWS_AGENT_URL 사용)
# WINDOWS_AGENT_API_KEY=your-secret-key-here     # install.ps1 실행 시 자동 생성됨

# MCP 서버 설정 파일 경로 (기본값: mcp_servers.json, 파일 없으면 MCP 비활성화)
# mcp_servers.json.example 을 참고해 mcp_servers.json 을 생성하세요
# MCP_SERVERS_CONFIG=mcp_servers.json

# LLM 설정
DEFAULT_LLM_PROVIDER=gemini   # claude | openai | gemini | ollama
# FALLBACK_LLM_PROVIDERS=claude,openai   # 실패 시 순서대로 폴백 (쉼표 구분)

# provider별 모델 설정 (미설정 시 각 provider 기본값 사용)
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.3
GEMINI_MODEL=gemini-3-flash-preview
OLLAMA_MODEL=llama3.3
