# LLM Providers (최소 하나 필요)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama (로컬 LLM, 설치 시 기본값 사용 가능)
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Slack (koclaw[slack] 설치 시 필요)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Discord (koclaw[discord] 설치 시 필요)
DISCORD_BOT_TOKEN=your-discord-bot-token

# LLM 설정
DEFAULT_LLM_PROVIDER=gemini   # claude | openai | gemini | ollama
# FALLBACK_LLM_PROVIDERS=claude,openai   # 실패 시 순서대로 폴백 (쉼표 구분)

# provider별 모델 설정 (미설정 시 각 provider 기본값 사용)
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.3
GEMINI_MODEL=gemini-3-flash-preview
OLLAMA_MODEL=llama3.3
